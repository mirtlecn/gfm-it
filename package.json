{
  "name": "gfm-it",
  "version": "0.1.0",
  "description": "Render GitHub Flavored Markdown into a complete HTML document.",
  "type": "module",
  "main": "index.js",
  "bin": {
    "gfm-it": "./cli.js"
  },
  "exports": {
    ".": "./index.js",
    "./cli": "./cli.js"
  },
  "files": [
    "cli.js",
    "index.js",
    "README.md"
  ],
  "scripts": {
    "test": "node --test",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "gfm",
    "markdown",
    "html",
    "renderer"
  ],
  "license": "MIT",
  "dependencies": {
    "gfm-addons": "^0.1.3",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "marked-alert": "^2.1.2",
    "marked-footnote": "^1.4.0",
    "marked-gfm-heading-id": "^4.1.3",
    "marked-highlight": "^2.2.3"
  }
}

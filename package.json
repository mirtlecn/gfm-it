{
  "name": "gfm-it",
  "version": "0.1.5",
  "description": "Render GitHub Flavored Markdown into a complete HTML document.",
  "type": "module",
  "main": "index.js",
  "bin": {
    "gfm-it": "./cli.js"
  },
  "exports": {
    ".": "./index.js",
    "./cli": "./cli.js",
    "./assets": "./assets.js",
    "./embedded": "./embedded.js",
    "./embedded.js": "./embedded.js",
    "./manifest.json": "./manifest.json",
    "./assets/*": "./assets/*"
  },
  "files": [
    "assets/",
    "assets.js",
    "cli.js",
    "embedded.js",
    "index.js",
    "manifest.json",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "assets:embed": "npm run build",
    "test": "npm run build && node --test",
    "version": "npm run build && git add assets assets.js manifest.json embedded.js embedded_assets.go package.json package-lock.json",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "gfm",
    "markdown",
    "html",
    "renderer"
  ],
  "license": "MIT",
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "marked-alert": "^2.1.2",
    "marked-footnote": "^1.4.0",
    "marked-gfm-heading-id": "^4.1.3",
    "marked-highlight": "^2.2.3",
    "vfile": "^6.0.3",
    "vfile-matter": "^5.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
